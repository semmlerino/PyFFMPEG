"""Comprehensive unit tests for ProcessPoolManager.

Tests the singleton pattern, subprocess execution, caching, timeout handling,
error conditions, and concurrent execution safety with REAL subprocess calls.
"""

import hashlib
import time
import threading
import concurrent.futures
from pathlib import Path
from unittest.mock import patch

import pytest

from process_pool_manager import (
    ProcessPoolManager,
    CommandCache, 
    PersistentBashSession,
    ProcessMetrics,
)


