class TestProcessMetrics:
    """Test ProcessMetrics tracking functionality."""
    
    def test_metrics_initialization(self, process_metrics):
        """Test ProcessMetrics initialization."""
        assert process_metrics.subprocess_calls == 0
        assert process_metrics.cache_hits == 0
        assert process_metrics.cache_misses == 0
        assert process_metrics.python_operations == 0
        assert process_metrics.total_response_time == 0.0
        assert process_metrics.response_count == 0
        assert process_metrics.start_time > 0
        
    def test_update_response_time(self, process_metrics):
        """Test response time tracking."""
        # Add some response times
        process_metrics.update_response_time(100.0)
        process_metrics.update_response_time(200.0)
        
        assert process_metrics.total_response_time == 300.0
        assert process_metrics.response_count == 2
        
    def test_get_report(self, process_metrics):
        """Test metrics report generation."""
        # Add some data
        process_metrics.subprocess_calls = 5
        process_metrics.python_operations = 3
        process_metrics.update_response_time(150.0)
        process_metrics.update_response_time(250.0)
        
        report = process_metrics.get_report()
        
        assert report["subprocess_calls"] == 5
        assert report["python_operations"] == 3
        assert report["average_response_ms"] == 200.0  # (150 + 250) / 2
        assert report["uptime_seconds"] > 0
        assert report["calls_per_minute"] > 0


# =============================================================================
# Test Concurrency and Thread Safety
# =============================================================================

class TestConcurrency:
    """Test concurrent execution and thread safety."""
    
    def test_concurrent_command_execution(self, process_manager_multiple_sessions):
        """Test multiple commands executing concurrently."""
        def worker(worker_id):
            results = []
            for i in range(3):
                cmd = f"echo worker_{worker_id}_command_{i}"
                result = process_manager_multiple_sessions.execute_workspace_command(cmd, timeout=10)
                results.append(result)
                time.sleep(0.1)  # Small delay
            return results
            
        # Run multiple workers concurrently
        with concurrent.futures.ThreadPoolExecutor(max_workers=3) as executor:
            futures = []
            for worker_id in range(3):
                future = executor.submit(worker, worker_id)
                futures.append(future)
                
            # Collect all results
            all_results = []
            for future in concurrent.futures.as_completed(futures):
                worker_results = future.result()
                all_results.extend(worker_results)
                
        # Verify all commands completed
        assert len(all_results) == 9  # 3 workers * 3 commands each
        for result in all_results:
            assert "worker_" in result
            assert "command_" in result
            
    def test_thread_safety_stress_test(self, process_manager_multiple_sessions):
        """Stress test thread safety with many concurrent operations."""
        results = {}
        results_lock = threading.Lock()
        
        def stress_worker(thread_id):
            thread_results = []
            for i in range(5):
                try:
                    cmd = f"echo thread_{thread_id}_iter_{i}"
                    result = process_manager_multiple_sessions.execute_workspace_command(cmd, timeout=15)
                    thread_results.append(result)
                except Exception as e:
                    thread_results.append(f"ERROR: {e}")
                    
            with results_lock:
                results[thread_id] = thread_results
                
        # Create many threads
        threads = []
        for thread_id in range(8):
            thread = threading.Thread(target=stress_worker, args=(thread_id,))
            threads.append(thread)
            thread.start()
            
        # Wait for all threads to complete
        for thread in threads:
            thread.join()
            
        # Verify all threads completed successfully
        assert len(results) == 8
        for thread_id, thread_results in results.items():
            assert len(thread_results) == 5
            for result in thread_results:
                if not result.startswith("ERROR:"):
                    assert f"thread_{thread_id}" in result


# =============================================================================
# Test Error Conditions
# =============================================================================

class TestErrorConditions:
    """Test error handling and recovery."""
    
    def test_invalid_command_handling(self, process_manager):
        """Test handling of invalid commands."""
        # Try to execute non-existent command
        try:
            result = process_manager.execute_workspace_command(
                "definitely_nonexistent_command_xyz123", timeout=5
            )
            # Due to command wrapping with || true, this might not fail
            assert isinstance(result, str)
        except Exception:
            # This is also acceptable - command might fail properly
            pass
            
        # Verify manager still works after error
        result = process_manager.execute_workspace_command("echo after_invalid", timeout=10)
        assert "after_invalid" in result
        
    def test_timeout_recovery(self, process_manager):
        """Test recovery after command timeout."""
        # Execute command that times out
        with pytest.raises(TimeoutError):
            process_manager.execute_workspace_command("sleep 10", timeout=1)
            
        # Verify manager can execute commands after timeout
        result = process_manager.execute_workspace_command("echo after_timeout", timeout=10)
        assert "after_timeout" in result
        
    def test_session_restart_after_failure(self, bash_session):
        """Test session restart after process failure."""
        # Kill the underlying process
        if bash_session._process:
            bash_session._process.kill()
            bash_session._process.wait()
            
        # Next command should trigger restart and work
        result = bash_session.execute("echo after_restart", timeout=10)
        assert "after_restart" in result


# =============================================================================
# Test Edge Cases and Additional Coverage
# =============================================================================

class TestEdgeCases:
    """Test edge cases and improve coverage."""
    
    def test_debug_verbose_mode(self):
        """Test debug verbose mode functionality."""
        # Test with debug environment variable set
        with patch.dict('os.environ', {'SHOTBOT_DEBUG_VERBOSE': '1'}):
            # Import fresh module to trigger debug setup
            import importlib
            import process_pool_manager
            importlib.reload(process_pool_manager)
            
            # Verify debug mode affects behavior
            cache = process_pool_manager.CommandCache()
            result = cache.get("nonexistent")
            assert result is None
            
    def test_bash_session_with_complex_output(self, bash_session):
        """Test bash session handling complex output."""
        # Command with escape sequences and special characters
        result = bash_session.execute("echo 'Line 1\nLine 2' | cat", timeout=10)
        assert "Line 1" in result
        
    def test_cache_with_custom_ttl(self, command_cache):
        """Test cache with custom TTL values."""
        # Test with 0 TTL (should expire immediately)
        command_cache.set("instant_expire", "value", ttl=0)
        time.sleep(0.1)
        assert command_cache.get("instant_expire") is None
        
        # Test with very long TTL
        command_cache.set("long_expire", "value", ttl=3600)
        assert command_cache.get("long_expire") == "value"
        
    def test_process_manager_get_instance_multiple_calls(self):
        """Test get_instance method multiple calls."""
        ProcessPoolManager._instance = None
        
        instance1 = ProcessPoolManager.get_instance()
        instance2 = ProcessPoolManager.get_instance()
        
        assert instance1 is instance2
        
        # Cleanup
        instance1.shutdown()
        ProcessPoolManager._instance = None
        
    def test_find_files_nonexistent_directory(self, process_manager):
        """Test file finding with nonexistent directory."""
        files = process_manager.find_files_python("/nonexistent/path", "*.txt")
        assert files == []
        
    def test_batch_execute_empty_commands(self, process_manager):
        """Test batch execute with empty command list."""
        results = process_manager.batch_execute([])
        assert results == {}
        
    def test_session_execute_internal_error(self, bash_session):
        """Test internal execute method error handling."""
        # Close the session stdin to trigger error
        if bash_session._process and bash_session._process.stdin:
            bash_session._process.stdin.close()
            
        # This should handle the error gracefully
        try:
            bash_session._execute_internal("echo test")
        except RuntimeError:
            pass  # Expected
            
    def test_cache_large_cleanup(self):
        """Test cache cleanup with large number of entries."""
        cache = CommandCache(default_ttl=1)
        
        # Add exactly 101 entries to trigger cleanup logic
        for i in range(101):
            cache.set(f"key_{i}", f"value_{i}", ttl=1)
            
        # Wait for expiration
        time.sleep(1.1)
        
        # Add one more to trigger cleanup
        cache.set("trigger", "cleanup")
        
        # Verify cleanup occurred
        stats = cache.get_stats()
        assert stats["size"] <= 101
        
    def test_session_process_death_during_execute(self, bash_session):
        """Test handling process death during execution."""
        # Start a command execution but don't wait for completion
        import threading
        
        def kill_process():
            time.sleep(0.5)  # Let command start
            if bash_session._process:
                bash_session._process.kill()
                
        killer_thread = threading.Thread(target=kill_process)
        killer_thread.start()
        
        # This should handle process death
        try:
            result = bash_session.execute("sleep 2", timeout=5)
        except (RuntimeError, TimeoutError):
            pass  # Either is acceptable
            
        killer_thread.join()
        
    def test_bash_session_escape_sequence_stripping(self, bash_session):
        """Test escape sequence stripping functionality."""
        # Test with command that might produce escape sequences
        result = bash_session.execute("echo -e '\033[31mRed Text\033[0m'", timeout=10)
        # Should not contain escape sequences
        assert '\033' not in result
        assert 'Red Text' in result
        
    def test_process_manager_metrics_with_python_operations(self, process_manager, tmp_path):
        """Test metrics tracking for Python operations."""
        initial_metrics = process_manager.get_metrics()
        initial_python_ops = initial_metrics.get("python_operations", 0)
        
        # Perform Python file operation
        test_dir = tmp_path / "metrics_test"
        test_dir.mkdir()
        (test_dir / "test.txt").touch()
        
        process_manager.find_files_python(str(test_dir), "*.txt")
        
        # Check metrics updated
        updated_metrics = process_manager.get_metrics()
        assert updated_metrics["python_operations"] > initial_python_ops
        
    def test_session_round_robin_with_failures(self, process_manager_multiple_sessions):
        """Test round-robin behavior when sessions fail."""
        # Execute commands to ensure sessions are created
        for i in range(5):
            result = process_manager_multiple_sessions.execute_workspace_command(f"echo test_{i}", timeout=10)
            assert f"test_{i}" in result
            
        # Verify sessions exist and round-robin works
        metrics = process_manager_multiple_sessions.get_metrics()
        session_stats = metrics.get("sessions", {})
        if "workspace" in session_stats:
            assert session_stats["workspace"]["pool_size"] > 0