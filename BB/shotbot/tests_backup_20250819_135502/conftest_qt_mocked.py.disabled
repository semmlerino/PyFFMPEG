"""Shared fixtures for pytest tests following best practices.

This conftest provides clean, isolated fixtures that:
- Mock external dependencies at boundaries
- Are fast and deterministic
- Don't require real Qt/GUI components
- Support both unit and integration testing
"""

import sys
import os
from pathlib import Path
from unittest.mock import Mock, MagicMock, patch
from typing import List

import pytest

# Disable pytest-qt plugin since we're mocking Qt
pytest_plugins = []

# Add parent directory to path before any imports
sys.path.insert(0, str(Path(__file__).parent.parent))

# =============================================================================
# Qt Mocking Setup
# =============================================================================

def setup_qt_mocks():
    """Setup Qt mocks before any Qt-dependent imports."""
    # Create mock modules
    qt_core = MagicMock()
    qt_widgets = MagicMock()
    qt_gui = MagicMock()
    
    # Setup Qt core classes
    qt_core.QObject = type('QObject', (object,), {})
    qt_core.Signal = MagicMock
    qt_core.Qt = MagicMock()
    qt_core.QTimer = MagicMock
    qt_core.QThread = MagicMock
    qt_core.QRunnable = MagicMock
    qt_core.QThreadPool = MagicMock
    qt_core.qVersion = MagicMock(return_value="6.0.0")
    qt_core.__version__ = "6.0.0"
    
    # Setup Qt widget classes  
    qt_widgets.QApplication = MagicMock
    qt_widgets.QApplication.instance = MagicMock(return_value=None)
    qt_widgets.QWidget = type('QWidget', (object,), {})
    qt_widgets.QMainWindow = type('QMainWindow', (object,), {})
    qt_widgets.QListWidget = type('QListWidget', (object,), {})
    qt_widgets.QGridLayout = MagicMock
    qt_widgets.QVBoxLayout = MagicMock
    qt_widgets.QHBoxLayout = MagicMock
    
    # Setup Qt GUI classes
    qt_gui.QPixmap = MagicMock
    qt_gui.QImage = MagicMock
    qt_gui.QPainter = MagicMock
    qt_gui.QIcon = MagicMock
    
    # Create PySide6 mock with required attributes for pytest-qt
    pyside6_mock = MagicMock()
    pyside6_mock.__version__ = "6.0.0"  # Required by pytest-qt
    pyside6_mock.QtCore = qt_core
    pyside6_mock.QtWidgets = qt_widgets
    pyside6_mock.QtGui = qt_gui
    
    # Register mocked modules
    sys.modules["PySide6"] = pyside6_mock
    sys.modules["PySide6.QtCore"] = qt_core
    sys.modules["PySide6.QtWidgets"] = qt_widgets
    sys.modules["PySide6.QtGui"] = qt_gui
    
    return qt_core, qt_widgets, qt_gui

# Setup Qt mocks before any imports
qt_core, qt_widgets, qt_gui = setup_qt_mocks()

# =============================================================================
# Model Imports (after Qt mocking)
# =============================================================================

# Import models that depend on Qt
from shot_model import Shot, ShotModel
from cache_manager import CacheManager

# =============================================================================
# Core Fixtures
# =============================================================================

@pytest.fixture
def mock_qt():
    """Provide access to mocked Qt modules."""
    return {
        'QtCore': qt_core,
        'QtWidgets': qt_widgets,
        'QtGui': qt_gui
    }


@pytest.fixture
def temp_cache_dir(tmp_path):
    """Create temporary cache directory."""
    cache_dir = tmp_path / "cache"
    cache_dir.mkdir()
    return cache_dir


@pytest.fixture
def cache_manager(temp_cache_dir):
    """Create a CacheManager with temporary directory."""
    return CacheManager(cache_dir=temp_cache_dir)


@pytest.fixture
def sample_shot():
    """Create a sample Shot instance."""
    return Shot(
        show="testshow",
        sequence="101_ABC",
        shot="0010",
        workspace_path="/shows/testshow/shots/101_ABC/101_ABC_0010"
    )


@pytest.fixture
def sample_shots():
    """Create a list of sample Shot objects."""
    return [
        Shot("show1", "seq1", "0010", "/shows/show1/shots/seq1/seq1_0010"),
        Shot("show1", "seq1", "0020", "/shows/show1/shots/seq1/seq1_0020"),
        Shot("show2", "seq2", "0030", "/shows/show2/shots/seq2/seq2_0030"),
    ]


@pytest.fixture
def shot_model(cache_manager):
    """Create a ShotModel with cache manager."""
    model = ShotModel(cache_manager=cache_manager)
    return model


@pytest.fixture
def shot_model_with_shots(shot_model, sample_shots):
    """Create a ShotModel pre-populated with shots."""
    shot_model.shots = sample_shots
    return shot_model


# =============================================================================
# Mock Fixtures
# =============================================================================

@pytest.fixture
def mock_subprocess():
    """Mock subprocess.run for testing commands."""
    with patch('subprocess.run') as mock_run:
        mock_result = Mock()
        mock_result.returncode = 0
        mock_result.stdout = "mock output"
        mock_result.stderr = ""
        mock_run.return_value = mock_result
        yield mock_run


@pytest.fixture
def mock_subprocess_ws(mock_subprocess):
    """Mock subprocess for workspace commands."""
    mock_subprocess.return_value.stdout = """workspace /shows/test/shots/seq1/seq1_0010
workspace /shows/test/shots/seq1/seq1_0020
workspace /shows/test/shots/seq2/seq2_0030"""
    return mock_subprocess


@pytest.fixture
def mock_process_pool_manager():
    """Mock ProcessPoolManager for testing shot workflows."""
    # Create a mock that behaves like ProcessPoolManager
    mock_manager = MagicMock()
    
    # Mock the Qt signals with emit method
    mock_signal = MagicMock()
    mock_signal.emit = MagicMock()
    mock_manager.command_completed = mock_signal
    mock_manager.command_failed = mock_signal
    
    # Default workspace output for consistent tests
    default_ws_output = """workspace /shows/test/shots/seq1/seq1_0010
workspace /shows/test/shots/seq1/seq1_0020
workspace /shows/test/shots/seq2/seq2_0030"""
    
    # Mock the execute_workspace_command method
    mock_manager.execute_workspace_command.return_value = default_ws_output
    
    # Mock other methods that might be called
    mock_manager.invalidate_cache.return_value = None
    mock_manager.get_metrics.return_value = {
        'subprocess_calls': 1,
        'cache_hits': 0,
        'cache_misses': 1,
        'average_response_ms': 100,
        'cache_hit_rate': 0,
        'sessions': {}
    }
    
    # Patch ProcessPoolManager.get_instance to return our mock
    with patch('process_pool_manager.ProcessPoolManager.get_instance', return_value=mock_manager):
        yield mock_manager


@pytest.fixture
def mock_filesystem(tmp_path):
    """Create mock filesystem structure for testing."""
    # Create test directory structure
    shows_dir = tmp_path / "shows"
    test_show = shows_dir / "testshow" / "shots" / "101_ABC" / "101_ABC_0010"
    test_show.mkdir(parents=True)
    
    # Create thumbnail directory
    thumb_dir = test_show / "publish" / "editorial" / "cutref" / "v001" / "jpg" / "1920x1080"
    thumb_dir.mkdir(parents=True)
    
    # Create test files
    (thumb_dir / "frame.1001.jpg").touch()
    (thumb_dir / "frame.1002.jpg").touch()
    
    return shows_dir


@pytest.fixture
def mock_time():
    """Mock time.time() for testing time-based features."""
    current_time = [1000.0]
    
    def get_time():
        return current_time[0]
    
    def advance(seconds):
        current_time[0] += seconds
    
    with patch('time.time', side_effect=get_time):
        yield advance


@pytest.fixture
def mock_path_exists():
    """Mock Path.exists() for testing."""
    with patch('pathlib.Path.exists') as mock_exists:
        mock_exists.return_value = True
        yield mock_exists


