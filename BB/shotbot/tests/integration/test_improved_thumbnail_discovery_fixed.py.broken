"""Test improved thumbnail discovery with flexible directory structures."""

import pytest
from pathlib import Path
from unittest.mock import patch
import tempfile
import shutil


class TestImprovedThumbnailDiscoveryFixed:
    """Fixed version of thumbnail discovery tests that avoids timeout issues."""

    def setup_method(self):
        """Set up test environment with minimal overhead."""
        # Create temporary directory for tests
        self.temp_dir = Path(tempfile.mkdtemp(prefix="shotbot_integration_"))
        self.shows_root = self.temp_dir / "shows"
        self.shows_root.mkdir(parents=True, exist_ok=True)

    def teardown_method(self):
        """Clean up test environment."""
        try:
            if hasattr(self, 'temp_dir') and self.temp_dir.exists():
                shutil.rmtree(self.temp_dir, ignore_errors=True)
        except Exception:
            pass  # Ignore cleanup errors

    def test_find_turnover_plate_without_input_plate_fixed(self):
        """Test finding turnover plates when input_plate directory doesn't exist."""
        # Import utilities locally to avoid import issues
        import sys
        from pathlib import Path
        sys.path.insert(0, str(Path(__file__).parent.parent.parent))
        
        from config import Config
        from utils import PathUtils
        
        # Create structure without input_plate subdirectory
        plate_path = (
            self.shows_root
            / "testshow"
            / "shots"
            / "seq01"
            / "seq01_shot01"
            / "publish"
            / "turnover"
            / "plate"
            / "FG01"
            / "v001"
            / "exr"
            / "4312x2304"
        )
        plate_path.mkdir(parents=True)

        # Create a test EXR file
        test_file = plate_path / "seq01_shot01_turnover-plate_FG01_v001.1001.exr"
        test_file.write_bytes(b"EXR_HEADER")  # Minimal content

        # Test that it finds the plate using direct path instead of Config patch
        result = PathUtils.find_turnover_plate_thumbnail(
            str(self.shows_root),
            "testshow",
            "seq01",
            "shot01",
        )

        assert result is not None
        assert result == test_file
        assert "FG01" in str(result)

    def test_find_turnover_plate_with_input_plate_fixed(self):
        """Test finding turnover plates with traditional input_plate directory."""
        # Import utilities locally
        import sys
        from pathlib import Path
        sys.path.insert(0, str(Path(__file__).parent.parent.parent))
        
        from utils import PathUtils
        
        # Create structure with input_plate subdirectory
        plate_path = (
            self.shows_root
            / "testshow"
            / "shots"
            / "seq01"
            / "seq01_shot01"
            / "publish"
            / "turnover"
            / "plate"
            / "input_plate"
            / "BG01"
            / "v001"
            / "exr"
            / "1920x1080"
        )
        plate_path.mkdir(parents=True)

        # Create a test EXR file
        test_file = plate_path / "seq01_shot01_turnover-plate_BG01_v001.1001.exr"
        test_file.write_bytes(b"EXR_HEADER")

        # Test that it finds the plate
        result = PathUtils.find_turnover_plate_thumbnail(
            str(self.shows_root),
            "testshow",
            "seq01",
            "shot01",
        )

        assert result is not None
        assert result == test_file
        assert "BG01" in str(result)

    def test_find_any_publish_thumbnail_without_publish_dir_fixed(self):
        """Test finding EXR files when publish directory doesn't exist."""
        # Import utilities locally
        import sys
        from pathlib import Path
        sys.path.insert(0, str(Path(__file__).parent.parent.parent))
        
        from utils import PathUtils
        
        # Create structure without publish subdirectory
        shot_path = (
            self.shows_root / "testshow" / "shots" / "seq01" / "seq01_shot01" / "some_path"
        )
        shot_path.mkdir(parents=True)

        # Create a test EXR file
        test_file = shot_path / "test.1001.exr"
        test_file.write_bytes(b"EXR_HEADER")

        # Test that it finds the file even without publish directory
        result = PathUtils.find_any_publish_thumbnail(
            str(self.shows_root),
            "testshow",
            "seq01",
            "shot01",
            max_depth=3,
        )

        assert result is not None
        assert result == test_file
        assert "1001" in result.name

    def test_plate_priority_order_fixed(self):
        """Test that FG plates are preferred over BG plates."""
        # Import utilities locally
        import sys
        from pathlib import Path
        sys.path.insert(0, str(Path(__file__).parent.parent.parent))
        
        from utils import PathUtils
        
        # Create structure with both FG and BG plates
        base_path = (
            self.shows_root
            / "testshow"
            / "shots"
            / "seq01"
            / "seq01_shot01"
            / "publish"
            / "turnover"
            / "plate"
        )

        # Create BG01 plate
        bg_path = base_path / "BG01" / "v001" / "exr" / "1920x1080"
        bg_path.mkdir(parents=True)
        bg_file = bg_path / "shot01_BG01.1001.exr"
        bg_file.write_bytes(b"BG_EXR")

        # Create FG01 plate
        fg_path = base_path / "FG01" / "v001" / "exr" / "1920x1080"
        fg_path.mkdir(parents=True)
        fg_file = fg_path / "shot01_FG01.1001.exr"
        fg_file.write_bytes(b"FG_EXR")

        # Test that FG01 is preferred
        result = PathUtils.find_turnover_plate_thumbnail(
            str(self.shows_root),
            "testshow",
            "seq01",
            "shot01",
        )

        assert result is not None
        assert result == fg_file
        assert "FG01" in str(result)

    def test_deeply_nested_exr_discovery_fixed(self):
        """Test finding deeply nested EXR files."""
        # Import utilities locally
        import sys
        from pathlib import Path
        sys.path.insert(0, str(Path(__file__).parent.parent.parent))
        
        from utils import PathUtils
        
        # Create a very deeply nested structure
        deep_path = (
            self.shows_root
            / "testshow"
            / "shots"
            / "seq01"
            / "seq01_shot01"
            / "publish"
            / "level1"
            / "level2"
            / "level3"
            / "level4"
            / "level5"
        )
        deep_path.mkdir(parents=True)

        # Create a test EXR file
        test_file = deep_path / "deep.1001.exr"
        test_file.write_bytes(b"DEEP_EXR")

        # Test that it finds the deeply nested file
        result = PathUtils.find_any_publish_thumbnail(
            str(self.shows_root),
            "testshow",
            "seq01",
            "shot01",
            max_depth=6,
        )

        assert result is not None
        assert result == test_file


# Run the tests if called directly
if __name__ == "__main__":
    import pytest
    pytest.main([__file__, "-v"])
