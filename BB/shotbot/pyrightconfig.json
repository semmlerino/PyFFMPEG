{
  "typeCheckingMode": "basic",
  "pythonVersion": "3.8",
  "venvPath": ".",
  "venv": "venv",
  "exclude": [
    "venv",
    "**/__pycache__",
    "build",
    "dist",
    "archived",
    "archive",
    "htmlcov",
    "sprite_candidates",
    "encoded_releases",
    "docs",
    "examples",
    "*.bak",
    "*.backup",
    "debug_*.py",
    "test_*.py",
    "standalone_*.py",
    "aggressive_cleanup.py",
    "analyze_mock_necessity.py",
    "cleanup_tests.py",
    "count_mocks.py",
    "fix_all_time_sleeps.py",
    "pytest_audit.py",
    "run_all_integration_tests.py",
    "run_performance_tests.py",
    "run_tests.py",
    "clean_test_runner.py",
    "Transfer.py",
    "transfer_cli.py",
    "setup_transfer_hook.py",
    "bundle_app.py",
    "demo_ui_improvements.py",
    "quick_test_check.py",
    "tests",
    "launcher_config.py",
    "launcher_model.py",
    "launcher_dialog.py",
    "command_launcher_qprocess.py",
    "enhanced_cache.py",
    "design_system.py",
    "main_window_improved.py",
    "performance_profiler.py",
    "memory_aware_cache.py",
    "memory_optimized_grid.py",
    "pattern_cache.py",
    "performance_monitor.py",
    "shot_grid_optimized.py",
    "shot_grid_delegate.py",
    "shot_grid_view.py",
    "shot_item_model.py",
    "threede_scene_finder_optimized.py",
    "thread_safe_manager.py",
    "thread_safe_worker.py",
    "thumbnail_loading_indicator.py",
    "thumbnail_widget_base.py",
    "timeout_config.py",
    "ui_components.py",
    "performance_analysis.py",
    "verify_tests.py",
    "tests_backup_*/**",
    "**/*.backup*",
    "**/*.bak*",
    "launcher_manager_threading_fix.py",
    "shot_grid_delegate_optimized.py",
    "shot_item_model_optimized.py", 
    "thread_health_integration_example.py",
    "thread_health_monitor.py",
    "*_optimized.py",
    "*_threading_fix.py",
    "*_integration_example.py",
    "accessibility_manager_complete.py",
    "process_pool_manager_optimized.py",
    "thumbnail_processor_optimized.py",
    "fix_*.py",
    "demo_*.py"
  ],
  "stubPath": ".",
  "reportMissingImports": "warning",
  "reportMissingTypeStubs": "warning",
  "reportUnnecessaryTypeIgnoreComment": "error",
  "reportIgnoreCommentWithoutRule": "error",
  "reportPrivateUsage": "warning",
  "reportUnknownMemberType": "information",
  "reportUnknownArgumentType": "information",
  "reportUnknownLambdaType": "information",
  "reportUnknownVariableType": "information",
  "reportUntypedFunctionDecorator": "warning",
  "reportUntypedClassDecorator": "warning",
  "reportUntypedBaseClass": "error",
  "reportUntypedNamedTuple": "error",
  "reportCallInDefaultInitializer": "warning",
  "reportImplicitStringConcatenation": "warning",
  "reportMissingSuperCall": "information",
  "reportPropertyTypeMismatch": "error",
  "reportFunctionMemberAccess": "error",
  "reportIncompatibleMethodOverride": "error",
  "reportIncompatibleVariableOverride": "error",
  "reportOverlappingOverload": "error"
}