{
  "typeCheckingMode": "basic",
  "pythonVersion": "3.8",
  "venvPath": ".",
  "venv": "venv",
  "exclude": [
    "venv",
    "**/__pycache__",
    "build",
    "dist",
    "archived",
    "archive",
    "htmlcov",
    "sprite_candidates",
    "encoded_releases",
    "docs",
    "examples",
    "*.bak",
    "*.backup",
    "debug_*.py",
    "test_*.py",
    "standalone_*.py",
    "aggressive_cleanup.py",
    "analyze_mock_necessity.py",
    "cleanup_tests.py",
    "count_mocks.py",
    "fix_all_time_sleeps.py",
    "pytest_audit.py",
    "run_all_integration_tests.py",
    "run_performance_tests.py",
    "run_tests.py",
    "clean_test_runner.py",
    "Transfer.py",
    "transfer_cli.py",
    "setup_transfer_hook.py",
    "bundle_app.py",
    "demo_ui_improvements.py",
    "quick_test_check.py",
    "tests"
  ],
  "stubPath": ".",
  "reportMissingImports": "warning",
  "reportMissingTypeStubs": "warning",
  "reportUnnecessaryTypeIgnoreComment": "error",
  "reportIgnoreCommentWithoutRule": "error",
  "reportPrivateUsage": "warning",
  "reportUnknownMemberType": "information",
  "reportUnknownArgumentType": "information",
  "reportUnknownLambdaType": "information",
  "reportUnknownVariableType": "information",
  "reportUntypedFunctionDecorator": "warning",
  "reportUntypedClassDecorator": "warning",
  "reportUntypedBaseClass": "error",
  "reportUntypedNamedTuple": "error",
  "reportCallInDefaultInitializer": "warning",
  "reportImplicitStringConcatenation": "warning",
  "reportMissingSuperCall": "warning",
  "reportPropertyTypeMismatch": "error",
  "reportFunctionMemberAccess": "error",
  "reportIncompatibleMethodOverride": "error",
  "reportIncompatibleVariableOverride": "error",
  "reportOverlappingOverload": "error"
}