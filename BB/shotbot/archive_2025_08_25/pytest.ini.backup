[pytest]
testpaths = tests
python_files = test_*.py
python_classes = Test*
python_functions = test_*
addopts = 
    -v
    --strict-markers
    --tb=short
    -p no:xvfb
    --timeout=120
    --timeout-method=thread
markers =
    unit: Unit tests (<100ms)
    integration: Integration tests
    slow: Slow running tests (>1s)
    qt: Tests requiring Qt (qtbot fixture)
    gui: GUI tests requiring display
    performance: Performance regression tests
    contract: Contract validation tests
    mutation: Mutation testing
    snapshot: Snapshot testing
    quality: Code quality tests
    stress: Stress tests that may take longer or use more resources

# xvfb plugin disabled via -p no:xvfb above