[run]
# Coverage configuration for ShotBot
# Focus on production code only, exclude test infrastructure and scripts

source = .
omit = 
    # Test directories and files
    tests/*
    test_*
    conftest.py
    */tests/*
    */test_*.py
    */__pycache__/*
    
    # Archive and backup files
    archive/*
    archived/*
    *.backup*
    *_backup*
    
    # Development and utility scripts
    run_*.py
    fix_*.py
    debug_*.py
    setup_*.py
    bundle_app.py
    clean_*.py
    cleanup_*.py
    analyze_*.py
    aggressive_cleanup.py
    count_mocks.py
    verify_tests.py
    pytest_audit.py
    quick_*.py
    minimal_test.py
    scan_all_modules.py
    Transfer.py
    transfer_cli.py
    add_test_markers.py
    
    # Performance testing and analysis
    performance_*.py
    standalone_*.py
    *performance_test*.py
    thread_health_*.py
    
    # Documentation and example files
    examples/*
    demo_*.py
    
    # Virtual environments and build artifacts
    venv/*
    */venv/*
    test_venv/*
    htmlcov/*
    
    # Configuration and metadata files
    pyproject.toml
    pyrightconfig.json
    pytest.ini
    pytest_*.ini
    requirements*.txt
    typecheck.sh
    install.sh
    
    # Legacy and backup implementations
    *_legacy.py
    *_optimized.py
    *_improved.py
    memory_aware_cache.py
    memory_optimized_grid.py
    pattern_cache.py
    enhanced_cache.py
    process_pool_manager.py
    thread_safe_manager.py
    thread_safe_worker.py
    *_qprocess.py
    
    # Type stub files
    *.pyi
    
    # Specific problem files that are experimental/debugging
    demo_ui_improvements.py
    design_system.py
    protocols.py
    shotbot_types.py
    timeout_config.py
    ui_components.py
    
    # System files
    shibokensupport/*
    signature_bootstrap.py

[report]
# Reporting configuration
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod
    pass
    except ImportError:

# Show missing lines in terminal output
show_missing = True

# Require minimum coverage percentage (set conservatively)
fail_under = 50

# Output precision
precision = 1

[html]
# HTML report configuration
directory = htmlcov
title = ShotBot Production Code Coverage Report

[xml]
# XML report for CI/CD integration
output = coverage.xml