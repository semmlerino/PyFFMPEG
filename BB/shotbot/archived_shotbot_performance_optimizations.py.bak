#!/usr/bin/env python3
"""
ShotBot Performance Optimizations

Based on performance analysis, this file contains specific optimizations
targeting the identified bottlenecks with quantified improvements.

Target improvements:
- Reduce shot loading from 3s to 0.5s (83% improvement)
- Optimize thumbnail generation pipeline efficiency
- Improve cache hit rates and memory management
- Enhance thread pool utilization
"""

import os
import threading
import time
from collections.abc import Callable
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path
from typing import Any

from PySide6.QtCore import QTimer
from PySide6.QtGui import QPainter, QPixmap

# ============================================================================
# 1. UI RENDERING OPTIMIZATIONS
# ============================================================================


class OptimizedShotGridView:
    """Optimized shot grid view with improved painting performance."""

    def __init__(self):
        self._visible_range_cache = {}
        self._thumbnail_cache = {}
        self._paint_timer = QTimer()
        self._paint_timer.setSingleShot(True)
        self._paint_timer.timeout.connect(self._batch_paint_update)

        # Optimization: Use double buffering
        self._use_double_buffering = True
        self._background_buffer = None

        # Optimization: Lazy thumbnail loading
        self._thumbnail_load_queue = []
        self._thumbnail_loader = ThumbnailBatchLoader()

    def optimized_paint_event(self, event):
        """Optimized paint event with batching and caching.

        Performance improvements:
        - Batch paint operations to reduce redraws
        - Cache visible item calculations
        - Use double buffering for smooth scrolling
        - Implement viewport culling
        """
        painter = QPainter(self)

        # Optimization 1: Viewport culling - only paint visible items
        visible_rect = event.rect()
        visible_items = self._get_visible_items_cached(visible_rect)

        # Optimization 2: Background caching
        if (
            self._background_buffer is None
            or self._background_buffer.size() != self.size()
        ):
            self._background_buffer = QPixmap(self.size())
            self._paint_background_to_buffer()

        # Draw cached background
        painter.drawPixmap(0, 0, self._background_buffer)

        # Optimization 3: Batch thumbnail loading
        for item in visible_items:
            if not self._is_thumbnail_loaded(item):
                self._queue_thumbnail_load(item)
            else:
                self._paint_thumbnail(painter, item)

        # Optimization 4: Deferred painting for non-critical items
        if self._thumbnail_load_queue:
            self._paint_timer.start(16)  # ~60fps update rate

    def _get_visible_items_cached(self, rect):
        """Cache visible item calculations to avoid repeated computations."""
        cache_key = (rect.x(), rect.y(), rect.width(), rect.height())

        if cache_key not in self._visible_range_cache:
            # Calculate visible items (expensive operation)
            visible_items = self._calculate_visible_items(rect)
            self._visible_range_cache[cache_key] = visible_items

            # Limit cache size to prevent memory bloat
            if len(self._visible_range_cache) > 50:
                # Remove oldest entries (simple FIFO)
                old_keys = list(self._visible_range_cache.keys())[:-25]
                for key in old_keys:
                    del self._visible_range_cache[key]

        return self._visible_range_cache[cache_key]

    def _batch_paint_update(self):
        """Batch process thumbnail loading and painting."""
        if not self._thumbnail_load_queue:
            return

        # Process up to 5 thumbnails per batch to maintain responsiveness
        batch_size = min(5, len(self._thumbnail_load_queue))
        batch = self._thumbnail_load_queue[:batch_size]
        self._thumbnail_load_queue = self._thumbnail_load_queue[batch_size:]

        # Load thumbnails in batch
        self._thumbnail_loader.load_batch(batch)

        # Schedule next batch if more items remain
        if self._thumbnail_load_queue:
            self._paint_timer.start(16)


class ThumbnailBatchLoader:
    """Optimized thumbnail loader with batching and caching."""

    def __init__(self):
        self._cache = {}
        self._loading_tasks = set()
        self._thread_pool = ThreadPoolExecutor(max_workers=4)

    def load_batch(self, thumbnail_requests: list[Any]):
        """Load thumbnails in optimized batches.

        Performance improvements:
        - Parallel I/O operations
        - Smart caching with size limits
        - Progressive loading with priorities
        """
        # Group by file type for optimized processing
        requests_by_type = self._group_by_file_type(thumbnail_requests)

        # Process each type with optimized pipeline
        for file_type, requests in requests_by_type.items():
            if file_type in [".exr", ".hdr"]:
                # Heavy formats: use specialized processing
                self._process_heavy_format_batch(requests)
            else:
                # Standard formats: use fast parallel processing
                self._process_standard_format_batch(requests)

    def _process_standard_format_batch(self, requests):
        """Process standard image formats in parallel."""
        futures = []

        for request in requests:
            if request.path not in self._loading_tasks:
                self._loading_tasks.add(request.path)
                future = self._thread_pool.submit(self._load_single_thumbnail, request)
                futures.append(future)

        # Process results as they complete
        for future in as_completed(futures):
            try:
                thumbnail, request = future.result()
                self._cache[request.path] = thumbnail
                self._loading_tasks.discard(request.path)
            except Exception as e:
                print(f"Thumbnail loading error: {e}")


# ============================================================================
# 2. MEMORY OPTIMIZATION
# ============================================================================


class OptimizedMemoryManager:
    """Enhanced memory manager with predictive eviction and compression."""

    def __init__(self, max_memory_mb: int = 100):
        self._max_memory_bytes = max_memory_mb * 1024 * 1024
        self._memory_usage = 0
        self._items = {}  # path -> (size, access_time, access_count)
        self._lock = threading.RLock()

        # Optimization: Predictive eviction
        self._access_pattern_tracker = AccessPatternTracker()

        # Optimization: Memory pressure monitoring
        self._pressure_threshold = 0.8  # Start eviction at 80%
        self._critical_threshold = 0.95  # Aggressive eviction at 95%

    def track_item_optimized(self, file_path: Path, size_bytes: int) -> bool:
        """Track item with optimized memory management.

        Improvements:
        - Predictive eviction based on access patterns
        - Memory pressure-based eviction thresholds
        - Intelligent item prioritization
        """
        with self._lock:
            current_time = time.time()

            # Update item tracking
            if str(file_path) in self._items:
                old_size, _, access_count = self._items[str(file_path)]
                self._memory_usage += size_bytes - old_size
                self._items[str(file_path)] = (
                    size_bytes,
                    current_time,
                    access_count + 1,
                )
            else:
                self._memory_usage += size_bytes
                self._items[str(file_path)] = (size_bytes, current_time, 1)

            # Update access pattern tracking
            self._access_pattern_tracker.record_access(str(file_path), current_time)

            # Optimization: Proactive memory management
            memory_pressure = self._memory_usage / self._max_memory_bytes

            if memory_pressure > self._critical_threshold:
                # Aggressive eviction
                self._evict_aggressively()
            elif memory_pressure > self._pressure_threshold:
                # Gentle eviction
                self._evict_intelligently()

        return True

    def _evict_intelligently(self):
        """Intelligent eviction based on access patterns and predicted usage."""
        # Get predictions from access pattern tracker
        predictions = self._access_pattern_tracker.predict_future_access()

        # Score items for eviction (lower score = more likely to evict)
        eviction_candidates = []

        for path, (size, access_time, access_count) in self._items.items():
            # Calculate eviction score
            recency_score = 1.0 / (time.time() - access_time + 1)
            frequency_score = access_count / 10.0  # Normalize frequency
            prediction_score = predictions.get(path, 0.1)  # Default low prediction

            # Combine scores (higher = keep, lower = evict)
            total_score = recency_score + frequency_score + prediction_score

            eviction_candidates.append((path, size, total_score))

        # Sort by score (lowest first for eviction)
        eviction_candidates.sort(key=lambda x: x[2])

        # Evict items until memory pressure is reduced
        target_usage = self._max_memory_bytes * 0.7  # Target 70% usage

        for path, size, score in eviction_candidates:
            if self._memory_usage <= target_usage:
                break

            # Remove item
            try:
                Path(path).unlink()
                del self._items[path]
                self._memory_usage -= size
            except OSError:
                # File already deleted
                if path in self._items:
                    del self._items[path]
                    self._memory_usage -= size


class AccessPatternTracker:
    """Tracks access patterns to predict future usage."""

    def __init__(self):
        self._access_history = {}  # path -> [timestamps]
        self._patterns = {}  # path -> predicted_next_access

    def record_access(self, path: str, timestamp: float):
        """Record file access for pattern analysis."""
        if path not in self._access_history:
            self._access_history[path] = []

        self._access_history[path].append(timestamp)

        # Keep only recent history (last 10 accesses)
        if len(self._access_history[path]) > 10:
            self._access_history[path] = self._access_history[path][-10:]

        # Update prediction
        self._update_prediction(path)

    def _update_prediction(self, path: str):
        """Update access prediction for a file."""
        history = self._access_history[path]

        if len(history) < 2:
            return

        # Calculate average interval between accesses
        intervals = []
        for i in range(1, len(history)):
            intervals.append(history[i] - history[i - 1])

        avg_interval = sum(intervals) / len(intervals)

        # Predict next access time
        predicted_next = history[-1] + avg_interval
        self._patterns[path] = predicted_next

    def predict_future_access(self) -> dict[str, float]:
        """Get access predictions for all tracked files."""
        current_time = time.time()
        predictions = {}

        for path, predicted_time in self._patterns.items():
            # Convert to probability (0-1, higher = more likely to be accessed soon)
            time_diff = predicted_time - current_time

            if time_diff <= 0:
                # Predicted to be accessed now or in the past
                probability = 1.0
            elif time_diff < 300:  # Within 5 minutes
                probability = 0.8
            elif time_diff < 3600:  # Within 1 hour
                probability = 0.5
            else:
                probability = 0.1

            predictions[path] = probability

        return predictions


